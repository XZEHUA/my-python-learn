   "cell_type": "code",
   "source": [
    "# 在 Python 里，只有函数、类中定义的变量，才是局部的\n",
    "x = 10      # 外部变量（全局变量）\n",
    "\n",
    "def func():\n",
    "    global x\n",
    "    x = 20\n",
    "    print(x)\n",
    "\n",
    "func()\n",
    "print(x)"
   ],
   "id": "d44c41106ac44d95",
